# UAT — new stack (greenfield apply). Runtime secrets: API_ENV_UAT_B64.

project_id = "project-c74d38dd-7e12-4d3f-bbf"
region     = "europe-west1"

cloud_run_service_name = "contactbook-api-uat"
allow_unauthenticated  = true
container_port         = 8080
cpu                    = "1"
memory                 = "1Gi"
min_instances          = 1
max_instances          = 2

env = {
  NODE_ENV = "production"
}

create_profile_photos_bucket = true
profile_photos_bucket_name   = "contactbook-profile-photos-uat-c74d38dd"

# TODO: add UAT web app origin when known (see gcp-ci-cutover.md)
profile_photos_cors_origins = [
  "https://contactbookten.vercel.app",
  "http://localhost:3000",
  "http://127.0.0.1:3000",
  "http://localhost:5173",
  "http://127.0.0.1:5173",
]

custom_domain = "uat.api.getcontactbook.com"
