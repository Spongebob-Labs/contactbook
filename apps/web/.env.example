# Browser-visible API base (no trailing slash on version path)
# Local dev API default port 8001; production uses 8000.
NEXT_PUBLIC_API_URL=http://localhost:8001/api

# Optional: use `apps/web/.env.local` (gitignored) for real Supabase keys.

# Local Supabase (from `supabase start` — Project URL / APIs)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Publishable (anon) key — copy from `supabase status` (do not commit real keys to git)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
