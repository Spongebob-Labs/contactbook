# PostgreSQL (e.g. Supabase, Neon, or local Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

PORT=8000

# Comma-separated browser origins allowed to call the API with credentials
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000"

JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Public base URL Twilio calls (no trailing slash), e.g. https://your-ngrok-url.ngrok.io
APP_PUBLIC_URL="http://localhost:8000"

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Google OAuth (People + Calendar)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/integrations/google/callback"
