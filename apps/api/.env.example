# Copy to `apps/api/.env` for local dev.
# Deployed envs: `apps/api/env/prod.env` and `apps/api/env/uat.env` (see `apps/api/env/README.md`).
# For GitHub Actions (CI Docker build, tests, CD migrate + Cloud Run):
# store base64-encoded contents in `API_ENV_PROD_B64` / `API_ENV_UAT_B64` (legacy fallback: `API_ENV_B64`).
# Optional: `API_ENV_CI_B64` — if set, CI uses it instead of `API_ENV_B64` (e.g. non-prod DB only in CI).
# Encode for GitHub: `./scripts/encode-env-for-gh.sh apps/api/env/prod.env` (or `uat.env`).
#
# PostgreSQL — local Supabase default (DB pooler port from `supabase start`)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Remote Supabase: pooler for the API, direct host for Prisma CLI migrations.
# prisma.config.ts sets datasource.url to DIRECT_URL ?? DATABASE_URL (Prisma 7 has no directUrl).
# DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# Optional: secrets / overrides in `apps/api/.env.local` (gitignored), loaded after `.env`.

# Local dev default: 8001. Production containers typically use 8000.
PORT=8001

# Comma-separated browser origins (include Vite web dev port 5173; prod uses 3000)
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000,http://localhost:8001,http://127.0.0.1:8001"

JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"
JWT_PHONE_VERIFY_EXPIRES_IN="10m"

# Session cookies (cb_access_token, cb_refresh_token, cb_user_id). SameSite=lax is fine for same-site dev.
# Cross-site browser (SPA on another origin than this API): use AUTH_COOKIE_SAME_SITE=none (requires HTTPS / COOKIE_SECURE).
AUTH_COOKIE_SAME_SITE="lax"
# Optional; omit so cookies are host-only for this API (typical for api.* + separate app origin).
# AUTH_COOKIE_DOMAIN=""
# Force Secure flag on cookies (defaults true when NODE_ENV=production).
# COOKIE_SECURE="true"

# Twilio webhook URL must match what Twilio calls (local dev often port 8001)
APP_PUBLIC_URL="http://localhost:8001"

# Web app URL used by OAuth callbacks to send users back to the browser app.
WEB_APP_URL="http://localhost:5173"

# Twilio (WhatsApp). TWILIO_WHATSAPP_FROM may be `+E164` or `whatsapp:+E164`; the API normalizes to `whatsapp:+E164`.
# If TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN are both empty: no outbound send (dry-run logs with the real code),
# and any 6-character code passes verify for an existing OTP session (local/dev only — do not ship prod without credentials).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Optional: Twilio Content API SID for WhatsApp connection invites (buttons / quick replies).
# When unset, invites use plain text with ACCEPT-<uuid> / DECLINE-<uuid> keywords.
TWILIO_WA_CONNECTION_CONTENT_SID=""

# Google OAuth (People + Calendar). Browser flow uses Supabase PKCE; tokens are stored encrypted
# via POST /api/v1/integrations/google/link-provider (see apps/web auth callback).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AES-256-GCM key for OAuth tokens at rest (32 bytes, base64). Generate: openssl rand -base64 32
OAUTH_TOKEN_ENCRYPTION_KEY_BASE64=""

# Profile photos (GCS). Upload via POST /api/v1/profile/me/photo; objects are public-read.
# Cloud Run service account needs roles/storage.objectAdmin on the bucket.
# Bucket CORS should allow GET/HEAD from web origins (see plan). Optional CDN: set GCS_PUBLIC_BASE_URL to CDN origin.
GCS_PROFILE_PHOTOS_BUCKET="contactbook-profile-photos-c74d38dd"
GCS_PUBLIC_BASE_URL="https://storage.googleapis.com/contactbook-profile-photos-c74d38dd"
# GCS_PROJECT_ID=""
