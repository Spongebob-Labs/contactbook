generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ==========================================
// DOMAIN ENUMS
// ==========================================

enum FieldCategory {
  IDENTITY
  PERSONAL
  WORK
  BUSINESS
  SOCIAL
  FINANCIAL
  CUSTOM
}

enum FieldType {
  PHONE
  LANDLINE
  FAX
  EMAIL
  ADDRESS
  URL
  SOCIAL_LINK
  PHOTO
  TEXT
  DATE
  JOB_TITLE
  COMPANY
  REG_NUMBER
  DEPARTMENT
  RELATION
  STATUS
  LOCATION_TRACKING
  BANK_ACCOUNT
  DIGITAL_WALLET
  CRYPTO_WALLET
  CUSTOM
}

enum CardType {
  BUSINESS
  PERSONAL
  PAYMENT
  CUSTOM
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ContactSource {
  GOOGLE
  ICLOUD
  CSV
  VCARD
  CALDAV
  CONTACTBOOK
}

enum OAuthProvider {
  GOOGLE
  MICROSOFT
  ICLOUD
}

enum WhatsappFlowState {
  IDLE
  AWAITING_CONNECTION_ACCEPT
  AWAITING_RECIPIENT_CARD_SELECTION
  AWAITING_REQUESTER_CARD_SELECTION
}

enum ConnectionInviteRecipientKind {
  CONTACT
  EXTERNAL
}

enum ConnectionInviteStatus {
  PENDING
  DECLINED
  CONVERTED
}

// ==========================================
// AUTH / SESSION (retained)
// ==========================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  /// National significant number (digits only, no country calling code).
  phone       String
  /// E.164 country calling prefix (e.g. +1, +44).
  countryCode String   @db.VarChar(8)
  firstName String
  lastName  String
  isActive  Boolean  @default(false)
  profileOnboardingCompletedAt DateTime? @map("profile_onboarding_completed_at")

  fieldGroups   FieldGroup[]
  cards         ContactCard[]

  initiatedConnections Connection[] @relation("Requester")
  receivedConnections  Connection[] @relation("Receiver")
  connectionInvites    ConnectionInvite[]

  contacts           Contact[]
  contactMergeGroups ContactMergeGroup[]
  integrations       IntegrationState[]
  travelEvents  TravelEvent[]
  tags          Tag[]

  oauthAccounts    OAuthAccount[]
  otpSessions      OtpSession[]
  whatsappSessions WhatsappSession[]
  refreshTokens    RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryCode, phone])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model FieldGroup {
  id       String        @id @default(uuid())
  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category FieldCategory
  name     String

  fields ProfileField[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, category])
  @@map("field_groups")
}

model ProfileField {
  id          String      @id @default(uuid())
  groupId     String
  group       FieldGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  type        FieldType
  label       String?
  isSensitive Boolean     @default(false)
  value       String?

  address       AddressDetail?
  bankAccount   BankAccountDetail?
  digitalWallet DigitalWalletDetail?
  cryptoWallet  CryptoWalletDetail?

  cardMappings CardFieldMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@map("profile_fields")
}

model ContactCard {
  id     String   @id @default(uuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  type   CardType @default(CUSTOM)

  fieldMappings CardFieldMapping[]
  requesterSharedConnections Connection[] @relation("RequesterSharedCard")
  receiverSharedConnections  Connection[] @relation("ReceiverSharedCard")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("contact_cards")
}

model CardFieldMapping {
  cardId  String
  fieldId String
  card    ContactCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  field   ProfileField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@id([cardId, fieldId])
  @@map("card_field_mappings")
}

model Connection {
  id                    String           @id @default(uuid())
  status                ConnectionStatus @default(PENDING)
  requesterId           String
  requester             User             @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiverId            String
  receiver              User             @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  requesterSharedCardId String?          @map("requester_shared_card_id")
  requesterSharedCard   ContactCard?     @relation("RequesterSharedCard", fields: [requesterSharedCardId], references: [id], onDelete: SetNull)
  receiverSharedCardId  String?          @map("receiver_shared_card_id")
  receiverSharedCard    ContactCard?     @relation("ReceiverSharedCard", fields: [receiverSharedCardId], references: [id], onDelete: SetNull)
  hasSharedBack         Boolean          @default(false)

  tags Tag[]

  whatsappSessions WhatsappSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requesterId, receiverId])
  @@index([requesterId, status])
  @@index([receiverId, status])
  @@map("connections")
}

model ConnectionInvite {
  id                   String                      @id @default(uuid())
  requesterId          String
  requester            User                        @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  recipientKind        ConnectionInviteRecipientKind
  recipientContactId   String?
  recipientCountryCode String                      @db.VarChar(8)
  recipientPhone       String
  status               ConnectionInviteStatus      @default(PENDING)
  expiresAt            DateTime
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  @@index([requesterId, recipientCountryCode, recipientPhone])
  @@index([requesterId, recipientContactId])
  @@map("connection_invites")
}

model AddressDetail {
  id           String       @id @default(uuid())
  fieldId      String       @unique
  profileField ProfileField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  street  String
  city    String
  state   String?
  pincode String?
  country String

  @@map("address_details")
}

model BankAccountDetail {
  id           String       @id @default(uuid())
  fieldId      String       @unique
  profileField ProfileField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  bankName      String
  accountHolder String
  accountNumber String
  iban          String?
  swiftBic      String?
  routingNumber String?
  ifsc          String?
  currency      String @default("USD")

  @@map("bank_account_details")
}

model DigitalWalletDetail {
  id           String       @id @default(uuid())
  fieldId      String       @unique
  profileField ProfileField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  platform     String
  handleOrLink String

  @@map("digital_wallet_details")
}

model CryptoWalletDetail {
  id           String       @id @default(uuid())
  fieldId      String       @unique
  profileField ProfileField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  network String
  address String

  @@map("crypto_wallet_details")
}

model IntegrationState {
  id                 String        @id @default(uuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  source             ContactSource
  syncToken          String?
  lastSyncAt         DateTime      @default(now())
  lastSyncAdded      Int           @default(0)
  lastSyncUpdated    Int           @default(0)
  lastSyncDeleted    Int           @default(0)
  lastSyncDuplicates Int           @default(0)

  @@unique([userId, source])
  @@map("integration_states")
}

model ContactMergeGroup {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts  Contact[]
  dedupKeys ContactDedupKey[]
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("contact_merge_groups")
}

model ContactDedupKey {
  id           String            @id @default(uuid())
  userId       String
  mergeGroupId String
  mergeGroup   ContactMergeGroup @relation(fields: [mergeGroupId], references: [id], onDelete: Cascade)
  kind         String
  value        String

  @@unique([userId, kind, value])
  @@index([mergeGroupId])
  @@map("contact_dedup_keys")
}

model Contact {
  id             String             @id @default(uuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  source         ContactSource
  externalId     String
  mergeGroupId   String?
  mergeGroup     ContactMergeGroup? @relation(fields: [mergeGroupId], references: [id], onDelete: SetNull)
  sourceRevision String?
  displayName    String?
  firstName      String?
  lastName       String?
  middleName     String?
  namePrefix     String?
  nameSuffix     String?
  nickname       String?
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  phones        ContactPhone[]
  emails        ContactEmail[]
  organizations ContactOrganization[]
  addresses     ContactAddress[]
  urls          ContactUrl[]

  @@unique([userId, source, externalId])
  @@index([userId, source, deletedAt])
  @@index([userId, displayName])
  @@index([mergeGroupId])
  @@map("contacts")
}

model ContactPhone {
  id        String  @id @default(uuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  value     String
  label     String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  @@index([contactId])
  @@map("contact_phones")
}

model ContactEmail {
  id        String  @id @default(uuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  value     String
  label     String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  @@index([contactId])
  @@map("contact_emails")
}

model ContactOrganization {
  id          String  @id @default(uuid())
  contactId   String
  contact     Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  companyName String?
  department  String?
  title       String?
  isPrimary   Boolean @default(false)
  sortOrder   Int     @default(0)

  @@index([contactId])
  @@map("contact_organizations")
}

model ContactAddress {
  id         String  @id @default(uuid())
  contactId  String
  contact    Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  street     String?
  city       String?
  region     String?
  postalCode String?
  country    String?
  label      String?
  isPrimary  Boolean @default(false)
  sortOrder  Int     @default(0)

  @@index([contactId])
  @@map("contact_addresses")
}

model ContactUrl {
  id        String  @id @default(uuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  value     String
  label     String?
  sortOrder Int     @default(0)

  @@index([contactId])
  @@map("contact_urls")
}

model TravelEvent {
  id                      String   @id @default(uuid())
  userId                  String
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  city                    String
  country                 String
  startDate               DateTime
  endDate                 DateTime
  isConfirmed             Boolean  @default(false)
  notifiedContacts        Json?
  /// Dedup key for Google Calendar–originated rows
  externalCalendarEventId String?
  whatsappSentAt          DateTime?
  title                   String?
  raw                     Json?

  createdAt DateTime @default(now())

  @@unique([userId, externalCalendarEventId])
  @@index([userId, startDate])
  @@map("travel_events")
}

model Tag {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  connections Connection[]

  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

model OAuthAccount {
  id                  String          @id @default(uuid())
  userId              String
  provider            OAuthProvider
  scopes              String
  accessToken         String
  refreshToken        String
  expiresAt           DateTime?
  /// Stable id from the provider (e.g. Google `sub`) when available.
  providerAccountId   String?
  /// Provider-specific persisted state (e.g. `{ "google": { "calendarSyncToken": "..." } }`).
  providerState     Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("oauth_accounts")
}

model OtpSession {
  id         String    @id @default(uuid())
  userId     String?
  phoneE164  String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneE164, expiresAt])
  @@map("otp_sessions")
}

model WhatsappSession {
  id            String            @id @default(uuid())
  userId        String?
  phoneE164     String
  state         WhatsappFlowState @default(IDLE)
  connectionId  String?
  correlationId String?
  metadata      Json?
  expiresAt     DateTime
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  connection Connection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([phoneE164, state])
  @@map("whatsapp_sessions")
}
