# UAT — copy to uat.env and fill secrets. Encode → GitHub secret API_ENV_UAT_B64.
# Cloud Run: contactbook-api-uat
# APP_PUBLIC_URL from: cd iac/envs/uat && tofu output -raw cloud_run_service_url

# PostgreSQL (prefer a separate UAT Supabase project)
DATABASE_URL="postgresql://postgres:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

PORT=8080

CORS_ORIGIN="https://contactbookten.vercel.app,http://localhost:5173,http://127.0.0.1:5173"

JWT_SECRET="change-me-uat-different-from-prod"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"
JWT_PHONE_VERIFY_EXPIRES_IN="10m"

AUTH_COOKIE_SAME_SITE="none"
COOKIE_SECURE="true"
APP_PUBLIC_URL="https://contactbook-api-uat-pnuvobkmza-oe.a.run.app"

WHATSAPP_PROVIDER="openwa"
OPENWA_BASE_URL="https://openwa-uat.internal.example"
OPENWA_API_KEY=""
OPENWA_SESSION_ID=""
OPENWA_SENDER_PHONE="919676240186"
OPENWA_WEBHOOK_SECRET=""
OPENWA_REQUEST_TIMEOUT_MS="5000"
OPENWA_DELIVERY_POLL_ATTEMPTS="10"
OPENWA_DELIVERY_POLL_INTERVAL_MS="250"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

OAUTH_TOKEN_ENCRYPTION_KEY_BASE64=""

# AES-256-GCM key for financial profile fields at rest (32 bytes, base64). Generate: openssl rand -base64 32
FINANCIAL_FIELD_ENCRYPTION_KEY_BASE64=""

GCS_PROFILE_PHOTOS_BUCKET="contactbook-profile-photos-uat-c74d38dd"
GCS_PUBLIC_BASE_URL="https://storage.googleapis.com/contactbook-profile-photos-uat-c74d38dd"
GCS_PROJECT_ID="project-c74d38dd-7e12-4d3f-bbf"
