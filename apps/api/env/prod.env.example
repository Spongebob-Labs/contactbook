# Prod — copy to prod.env and fill secrets. Encode → GitHub secret API_ENV_PROD_B64.
# Cloud Run: contactbook-api
# APP_PUBLIC_URL from: cd iac/envs/prod && tofu output -raw cloud_run_service_url

# PostgreSQL (use a dedicated Prod Supabase project in production)
DATABASE_URL="postgresql://postgres:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

PORT=8080

CORS_ORIGIN="https://contactbookten.vercel.app,http://localhost:5173,http://127.0.0.1:5173"

JWT_SECRET="change-me-use-openssl-rand-base64-32"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"
JWT_PHONE_VERIFY_EXPIRES_IN="10m"

AUTH_COOKIE_SAME_SITE="none"
COOKIE_SECURE="true"
APP_PUBLIC_URL="https://contactbook-api-pnuvobkmza-oe.a.run.app"
WEB_APP_URL="https://contactbookten.vercel.app"

WHATSAPP_PROVIDER="openwa"
OPENWA_BASE_URL="https://openwa.internal.example"
OPENWA_API_KEY=""
OPENWA_SESSION_ID=""
OPENWA_SENDER_PHONE="919676240186"
OPENWA_WEBHOOK_SECRET=""
OPENWA_REQUEST_TIMEOUT_MS="5000"
OPENWA_DELIVERY_POLL_ATTEMPTS="10"
OPENWA_DELIVERY_POLL_INTERVAL_MS="250"
LOGIN_BROADCAST_ENABLED="false"
LOGIN_BROADCAST_RECIPIENTS="+919587746347,+31627452799,+919347243575"

TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_VERIFY_SERVICE_SID="VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_WHATSAPP_FROM="whatsapp:+1XXXXXXXXXX"
TWILIO_OTP_CONTENT_SID="HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Debug-only: skips WhatsApp OTP delivery and accepts any six-digit OTP.
DUMMY_OTP_LOGIN_ENABLED="false"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

OAUTH_TOKEN_ENCRYPTION_KEY_BASE64=""

# AES-256-GCM key for financial profile fields at rest (32 bytes, base64). Generate: openssl rand -base64 32
FINANCIAL_FIELD_ENCRYPTION_KEY_BASE64=""

GCS_PROFILE_PHOTOS_BUCKET="contactbook-profile-photos-c74d38dd"
GCS_PUBLIC_BASE_URL="https://storage.googleapis.com/contactbook-profile-photos-c74d38dd"
